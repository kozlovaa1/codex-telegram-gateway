[Unit]
Description=Codex Telegram Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/srv/projects/codex-telegram-gateway
EnvironmentFile=/srv/projects/codex-telegram-gateway/.env
ExecStart=/srv/projects/codex-telegram-gateway/.venv/bin/python3 -m codex_telegram_gateway --config /srv/projects/codex-telegram-gateway/config.toml --env-file /srv/projects/codex-telegram-gateway/.env
Restart=always
RestartSec=5
TimeoutStopSec=20
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/srv/projects/codex-telegram-gateway /srv/infra /srv/openclaw /srv/projects /var/lib/codex-telegram-gateway /var/log/codex-telegram-gateway /home/deploy/.npm-global /home/deploy/.codex

[Install]
WantedBy=multi-user.target
